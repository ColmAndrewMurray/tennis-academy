# ═══════════════════════════════════════════════════════════════════
# Tennis Academy — Environment Variables
#
# Copy this file to .env (in the tennis-academy/server/ folder)
# and fill in your values. NEVER commit .env to source control.
# ═══════════════════════════════════════════════════════════════════

# ── Stripe (TEST KEYS ONLY — find these at https://dashboard.stripe.com/test/apikeys) ──
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_SECRET_KEY

# Webhook signing secret — from Stripe CLI or Dashboard > Webhooks
# Run: stripe listen --forward-to localhost:3001/api/webhook
# The CLI will print your webhook signing secret.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── URLs ───────────────────────────────────────────────────────────
# The URL where your frontend is running.
# In development: http://localhost:5173
# In production: your actual domain (e.g. https://tennisacademy.ie)
FRONTEND_URL=http://localhost:5173

# ── Server ─────────────────────────────────────────────────────────
PORT=3001

# ── Optional: Academy email (for future email notifications) ───────
# ACADEMY_EMAIL=info@tennisacademy.ie
